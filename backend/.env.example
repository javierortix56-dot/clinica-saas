# =============================================================================
# Backend (Fase 8) — variables de entorno. Copiar a `.env` y completar.
# NO commitear el `.env` real (está en .gitignore).
# =============================================================================

# --- Postgres / Supabase ---
# Connection string del POOLER (pgbouncer) para el runtime de la app.
# IMPORTANTE (Paso 5 §2): el bot debe conectarse con el rol least-privilege
# `clinic_bot` (BYPASSRLS + sin acceso a clinical_notes, migración 0006), no con
# el rol postgres. Apuntá DATABASE_URL a las credenciales de clinic_bot.
DATABASE_URL=
# Connection string DIRECTA (puerto 5432) para `prisma db pull` / introspección.
DIRECT_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Token de acceso (temporal ahora; permanente vía System User luego).
WHATSAPP_ACCESS_TOKEN=
# String que elegís vos para verificar el webhook (GET challenge).
WHATSAPP_VERIFY_TOKEN=
# App Secret (Settings > Basic) para validar la firma X-Hub-Signature-256.
WHATSAPP_APP_SECRET=

# --- LLM ---
# 'gemini' | 'anthropic' | 'openai'
LLM_PROVIDER=gemini
# API key de Google AI Studio (aistudio.google.com). Debe tener prefijo 'AIza';
# las keys 'AQ.'/'IQ.' (tokens OAuth2) NO autentican vía SDK y dan 401 (ver §0).
GEMINI_API_KEY=
# Modelo de Gemini a usar. Opcional; default 'gemini-2.5-flash'.
GEMINI_MODEL=gemini-2.5-flash

# --- Agenda ---
# Colchón de adyacencia (minutos) para priorizar turnos back-to-back en
# proponer_turnos. Opcional; default 5.
SCHEDULING_ADJACENCY_BUFFER_MIN=5

# --- Infra ---
# REQUERIDO (Paso 6): cola BullMQ + mutex por conversación.
REDIS_URL=
# UUID fijo que representa al bot en la auditoría (runAsBot).
BOT_ACTOR_ID=
# Concurrencia global del worker. Opcional; default 5.
QUEUE_CONCURRENCY=5
# TTL del mutex por conversación (ms). Opcional; default 120000 (renovado por heartbeat).
QUEUE_LOCK_TTL_MS=120000
# Delay de reencolado al perder el lock por contención (ms). Opcional; default 1000.
QUEUE_CONTENTION_DELAY_MS=1000
PORT=3000

# --- Google Calendar (opcional — dejar vacío si no usás GCal) ---
# Credenciales OAuth de tipo "Web application" en Google Cloud Console.
# Callback URI que registrás en Google: https://tu-backend.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# URL del frontend para redirigir tras el callback (sin trailing slash).
FRONTEND_URL=
# Notificaciones push (tiempo real Google -> App). Opcional:
#  - GOOGLE_WEBHOOK_URL: URL pública del webhook. Si se deja vacío, se deriva
#    del origin de GOOGLE_REDIRECT_URI + /google-calendar/webhook.
#  - GOOGLE_SITE_VERIFICATION: nombre del archivo de verificación de dominio que
#    da Search Console (método "HTML file"), ej: google1a2b3c4d.html. Necesario
#    para que Google autorice este dominio como receptor de notificaciones push.
GOOGLE_WEBHOOK_URL=
GOOGLE_SITE_VERIFICATION=

# --- Diagnóstico (opcional) ---
# 'true' fuerza a Prisma a conectarse por DIRECT_URL (conexión directa 5432) en
# lugar de DATABASE_URL (pooler 6543). Útil para aislar fallos de auth del pooler.
# PRISMA_USE_DIRECT_URL=false
